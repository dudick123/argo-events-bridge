# Akuity API
AKUITY_BASE_URL=http://localhost:8080
AKUITY_ORG_ID=local-dev
AKUITY_INSTANCE_ID=local-instance
AKUITY_API_KEY=dev-key
AKUITY_APP_LABEL_SELECTOR=env=prod
AKUITY_MIN_REQUEST_INTERVAL_MS=1000
AKUITY_MAX_RETRIES=3

# Polling
POLL_INTERVAL_SECONDS=15
STABILIZATION_WINDOW_SECONDS=300

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_TTL_SECONDS=86400

# ServiceNow
SNOW_BASE_URL=http://localhost:8081
SNOW_API_KEY=dev-key
SNOW_MAX_RETRIES=3
SNOW_RETRY_BACKOFF_BASE_MS=2000
SNOW_TIMEOUT_SECONDS=30

# Observability
LOG_LEVEL=INFO
DATADOG_STATSD_HOST=localhost
DATADOG_STATSD_PORT=8125
SERVICE_NAME=change-bridge
ENV=prod
